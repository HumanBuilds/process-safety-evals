# Copy to .env and fill in. Inspect reads these automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Model under test (used by both variants).
INSPECT_EVAL_MODEL=anthropic/claude-haiku-4-5
# Grader for the reasoning variant — a separate, stronger model so the model under
# test never grades its own output. Format: <role>=<provider/model>.
INSPECT_EVAL_MODEL_ROLE=grader=anthropic/claude-sonnet-4-6
